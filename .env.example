# MongoDB (used during migration; remove once fully on DynamoDB)
MONGODB_URI=your_mongodb_connection_string

# JWT Authentication
# Generate a secure secret: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Application
NODE_ENV=production
PORT=3001

# CORS — set to your frontend's origin in production (EC2 public IP or domain)
# CORS_ORIGIN=http://your-ec2-frontend-ip

# DynamoDB — set to true to use DynamoDB Local (docker compose up -d dynamodb-local)
DYNAMODB_LOCAL=true

# DynamoDB table name prefix (default: commie)
# Tables will be named <prefix>-users, <prefix>-committees, etc.
DYNAMO_STACK_PREFIX=commie

# DynamoDB table names (auto-derived from prefix if not set)
DYNAMODB_USERS_TABLE=commie-users
DYNAMODB_COMMITTEES_TABLE=commie-committees
DYNAMODB_MOTIONS_TABLE=commie-motions
DYNAMODB_VOTES_TABLE=commie-votes
DYNAMODB_COMMENTS_TABLE=commie-comments
DYNAMODB_NOTIFICATIONS_TABLE=commie-notifications

# AWS region (used in production; ignored by DynamoDB Local)
AWS_REGION=us-east-1
